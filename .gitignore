__pycache__/
*.py[cod]
HANDOFF.md
# Internal design specs, implementation plans, and superpowers workflow
# artifacts. Operator-local; not part of the public-facing documentation
# in `documentation/`. Keep on disk for development history.
docs/
.env
.env.local
*.egg-info/
dist/
build/
.venv/
venv/
python-runtime/
.python-standalone-runtime/
messages/
transcripts/
recordings/
.worktrees/
.pytest_cache/
.pytest-tmp/

# Private per-business configs are ignored by default; only explicitly tracked production configs ship.
# Any other YAML in config/businesses/ is operator-local.
config/businesses/*.yaml
config/businesses/*.yaml.*.bak

# Per-business calendar credentials (service-account keys, OAuth tokens, OAuth client JSON)
secrets/*
!secrets/.gitkeep
