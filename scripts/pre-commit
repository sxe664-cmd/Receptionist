#!/usr/bin/env bash
# =============================================================================
# Git Pre-Commit Hook for AIReceptionist
#
# This hook:
#   0. Scans staged files for API key leaks (BLOCKS commit)
#   1. Checks if receptionist/ code was modified in staged changes
#   2. If so, warns if no documentation/ files were also staged
#   3. Runs pytest and blocks the commit if tests fail
#
# Install with: bash scripts/install-hooks.sh
# =============================================================================

set -euo pipefail

# Colors for terminal output (only when stdout is a terminal)
if [ -t 1 ]; then
    RED='\033[0;31m'
    YELLOW='\033[1;33m'
    GREEN='\033[0;32m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    NC='\033[0m' # No Color
else
    RED=''
    YELLOW=''
    GREEN=''
    CYAN=''
    BOLD=''
    NC=''
fi

echo ""
echo -e "${CYAN}${BOLD}[pre-commit]${NC} Running pre-commit checks..."
echo ""

# ---------------------------------------------------------------------------
# Step 0: Scan staged files for API key leaks
# ---------------------------------------------------------------------------

SECRETS_FOUND=false

# Files to skip when scanning for secrets
SKIP_PATTERN='\.env\.example$|\.gitignore$|LICENSE$|\.md$'

for file in $(git diff --cached --name-only --diff-filter=ACDMR 2>/dev/null || true); do
    # Skip excluded files
    if echo "$file" | grep -qE "$SKIP_PATTERN"; then
        continue
    fi

    # Get staged content of the file
    CONTENT=$(git show ":$file" 2>/dev/null || true)
    if [ -z "$CONTENT" ]; then
        continue
    fi

    # OpenAI keys: sk-proj-... or sk-... (20+ chars)
    if echo "$CONTENT" | grep -qE 'sk-proj-[A-Za-z0-9_-]{20,}|sk-[A-Za-z0-9]{20,}'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: OpenAI API key${NC}"
        SECRETS_FOUND=true
    fi

    # LiveKit keys: lk_ or API...
    if echo "$CONTENT" | grep -qE 'lk_[A-Za-z0-9]{10,}'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: LiveKit key${NC}"
        SECRETS_FOUND=true
    fi

    # AWS keys
    if echo "$CONTENT" | grep -qE 'AKIA[0-9A-Z]{16}'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: AWS access key${NC}"
        SECRETS_FOUND=true
    fi

    # GitHub tokens
    if echo "$CONTENT" | grep -qE 'ghp_[A-Za-z0-9]{36}|github_pat_[A-Za-z0-9_]{82}'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: GitHub token${NC}"
        SECRETS_FOUND=true
    fi

    # Stripe keys
    if echo "$CONTENT" | grep -qE 'sk_live_[A-Za-z0-9]{20,}'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: Stripe secret key${NC}"
        SECRETS_FOUND=true
    fi

    # Generic: KEY=, SECRET=, TOKEN= with real values (not placeholders)
    if echo "$CONTENT" | grep -E '(API_KEY|API_SECRET|SECRET_KEY|ACCESS_TOKEN)=['\''"]?[A-Za-z0-9+/=_-]{20,}' | grep -qvE 'your-|example|placeholder|changeme|xxx'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: Possible API key in variable assignment${NC}"
        SECRETS_FOUND=true
    fi

    # YAML/raw config values: allow ${ENV_VAR} placeholders, flag pasted secrets.
    if echo "$file" | grep -qE '\.ya?ml$' && \
       echo "$CONTENT" | grep -E '(^|[[:space:]])(password|api[_-]?key|secret|token|private[_-]?key|client[_-]?secret|bearer|auth[_-]?token|webhook[_-]?token):[[:space:]]*['\''"]?[A-Za-z0-9+/=_-]{16,}' | \
       grep -qvE '\$\{|your-|example|placeholder|changeme|xxx'; then
        echo -e "${RED}${BOLD}[pre-commit] SECRET DETECTED${NC}${RED} in ${file}: Possible raw secret in YAML${NC}"
        SECRETS_FOUND=true
    fi
done

if [ "$SECRETS_FOUND" = true ]; then
    echo ""
    echo -e "${RED}${BOLD}[pre-commit] COMMIT BLOCKED${NC}${RED}: API keys or secrets detected in staged files.${NC}"
    echo -e "${RED}Remove the secrets and use .env files instead.${NC}"
    echo -e "${RED}If this is a false positive, use: git commit --no-verify${NC}"
    echo ""
    exit 1
fi

# ---------------------------------------------------------------------------
# Step 1: Detect code and documentation changes in staged files
# ---------------------------------------------------------------------------

CODE_CHANGED=false
DOCS_CHANGED=false

# Get list of staged files (added, modified, or deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACDMR 2>/dev/null || true)

for file in $STAGED_FILES; do
    case "$file" in
        receptionist/*)
            CODE_CHANGED=true
            ;;
        documentation/*)
            DOCS_CHANGED=true
            ;;
        HANDOFF.md)
            DOCS_CHANGED=true
            ;;
    esac
done

# ---------------------------------------------------------------------------
# Step 2: Documentation reminder
# ---------------------------------------------------------------------------

if [ "$CODE_CHANGED" = true ]; then
    echo -e "${CYAN}[pre-commit]${NC} Detected changes in ${BOLD}receptionist/${NC} source code."
    echo ""

    if [ "$DOCS_CHANGED" = true ]; then
        echo -e "  ${GREEN}OK${NC} Documentation files are also staged. Good."
    else
        echo -e "  ${YELLOW}${BOLD}WARNING${NC}${YELLOW}: Code in receptionist/ was modified, but NO documentation${NC}"
        echo -e "  ${YELLOW}files were staged (documentation/, HANDOFF.md).${NC}"
        echo ""
        echo -e "  ${YELLOW}Please review whether documentation needs updating:${NC}"
        echo -e "  ${YELLOW}  - documentation/   (public docs)${NC}"
        echo -e "  ${YELLOW}  - HANDOFF.md       (project handoff document)${NC}"
        echo -e "  ${YELLOW}  - documentation/CHANGELOG.md (changelog)${NC}"
        echo ""
        echo -e "  ${YELLOW}See CLAUDE.md for the code-to-documentation mapping.${NC}"
        echo ""
        echo -e "  ${CYAN}(This is a warning only — the commit will not be blocked.)${NC}"
    fi

    echo ""
fi

# ---------------------------------------------------------------------------
# Step 3: Run pytest — block commit if tests fail
# ---------------------------------------------------------------------------

echo -e "${CYAN}[pre-commit]${NC} Running ${BOLD}pytest${NC}..."
echo ""

if pytest --tb=short -q 2>&1; then
    echo ""
    echo -e "${GREEN}${BOLD}[pre-commit]${NC}${GREEN} All tests passed.${NC}"
else
    echo ""
    echo -e "${RED}${BOLD}[pre-commit] COMMIT BLOCKED${NC}${RED}: pytest failed.${NC}"
    echo -e "${RED}Fix the failing tests before committing.${NC}"
    echo ""
    exit 1
fi

echo ""
echo -e "${GREEN}${BOLD}[pre-commit]${NC}${GREEN} All checks passed. Proceeding with commit.${NC}"
echo ""
exit 0
