LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# Production dispatch name. Leave as "receptionist" unless your LiveKit
# dispatch rule uses a different roomConfig.agents[].agentName. Set to an
# empty value only for local wildcard/dev dispatch testing.
RECEPTIONIST_AGENT_NAME=receptionist

# Required for API-key OpenAI auth. Optional when every business YAML uses
# voice.auth.type: "oauth_codex" (see documentation/chatgpt-oauth-setup.md).
OPENAI_API_KEY=your-openai-api-key

# --------------------------------------------------------------------------
# Optional variables — only needed if you enable the corresponding feature
# in a business's YAML config. These are referenced via ${VAR} interpolation.
# --------------------------------------------------------------------------

# SMTP email sender (referenced by email.sender.smtp.*)
# SMTP_USERNAME=receptionist@acmedental.com
# SMTP_PASSWORD=your-smtp-app-password
# For config/businesses/santiago.yaml with Gmail SMTP:
# SMTP_USERNAME=santiagoespinozac73@gmail.com
# SMTP_PASSWORD=your-google-app-password

# Resend email sender (referenced by email.sender.resend.api_key)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# EXAMPLE_RESEND_API_KEY=re_xxxxxxxxxxxx        # used by example-workers-comp.yaml

# Twilio SMS sender (referenced by sms.provider.*)
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_FROM_NUMBER=+15557654321

# S3-compatible recording storage (LiveKit Egress reads AWS creds from env)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# Example: Slack webhook header used in a webhook channel's headers block
# SLACK_TOKEN=xoxb-your-token

# --------------------------------------------------------------------------
# Google Calendar integration: credentials live in secrets/<business>/, NOT in
# env vars. See documentation/google-calendar-setup.md.
# No new env vars are required for calendar — the .env file is unaffected.
# --------------------------------------------------------------------------
