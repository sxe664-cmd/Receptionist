{
  "name": "ai-receptionist-desktop",
  "version": "0.1.19",
  "private": false,
  "description": "Desktop console for AIReceptionist",
  "main": "desktop/main.js",
  "type": "commonjs",
  "scripts": {
    "desktop": "electron desktop/main.js",
    "desktop:dev": "node scripts/desktop-dev.js",
    "desktop:runtime:build": "node scripts/build-python-runtime.js",
    "desktop:check": "node --check desktop/main.js && node --check desktop/preload.js && node --check desktop/appointment_email.js && node --check desktop/appointment_menu.js && node --check desktop/renderer.js",
    "desktop:dist": "npm run desktop:runtime:build && electron-builder --win nsis --mac dmg zip --x64 --arm64 --publish never",
    "desktop:dist:win": "npm run desktop:runtime:build && electron-builder --win nsis --x64 --publish never",
    "desktop:dist:mac": "npm run desktop:runtime:build && electron-builder --mac dmg zip --arm64 --publish never",
    "desktop:release:win": "npm run desktop:runtime:build && electron-builder --win nsis --x64 --publish always",
    "desktop:release:mac": "npm run desktop:runtime:build && electron-builder --mac dmg zip --arm64 --publish always"
  },
  "devDependencies": {
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.hira.aireceptionist.desktop",
    "productName": "HIRA Receptionist Console",
    "asar": false,
    "files": [
      "desktop/**/*",
      "receptionist/**/*",
      "config/businesses/santiago.yaml",
      "config/businesses/santiago-contacts.yaml",
      "scripts/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "desktop/assets"
    },
    "extraResources": [
      {
        "from": "desktop/oauth/google-calendar-oauth-client.json",
        "to": "oauth/google-calendar-oauth-client.json"
      },
      {
        "from": "python-runtime",
        "to": "python-runtime"
      }
    ],
    "win": {
      "artifactName": "AIReceptionist-Windows-Setup.${ext}",
      "icon": "desktop/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "artifactName": "AIReceptionist-macOS.${ext}",
      "icon": "desktop/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "sxe664-cmd",
        "repo": "Receptionist"
      }
    ]
  }
}
